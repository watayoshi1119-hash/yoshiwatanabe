---
import { getCollection, render } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const entries = (await getCollection('diary')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const latest = entries[0];
const { Content } = await render(latest);
---
<BaseLayout title="日記">
  <style>
    .diary-wrap { max-width: 680px; margin: 0 auto; }
    .entry-date {
      font-size: 0.85rem;
      color: #aaa;
      margin-bottom: 1.2rem;
      letter-spacing: 0.05em;
    }
    .entry-body :global(p) { margin-bottom: 0.8rem; line-height: 1.9; }
  </style>

  <div class="diary-wrap">
    <div class="entry-date">【{latest.data.date}】</div>
    <div class="entry-body"><Content /></div>
  </div>
</BaseLayout>
