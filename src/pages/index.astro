---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [...new Set(posts.map(p => p.data.category))];

// objectBoundingBox座標(0-1)でSVGパスを生成（8つの凹凸）
function generateBlobPath(outerR: number[], innerR: number[]) {
  const cx = 0.5, cy = 0.5;
  const n = 8;
  const pts: [number, number][] = [];
  for (let i = 0; i < n; i++) {
    const outerAngle = (i / n) * 2 * Math.PI - Math.PI / 2;
    const innerAngle = outerAngle + Math.PI / n;
    pts.push([cx + outerR[i] * Math.cos(outerAngle), cy + outerR[i] * Math.sin(outerAngle)]);
    pts.push([cx + innerR[i] * Math.cos(innerAngle), cy + innerR[i] * Math.sin(innerAngle)]);
  }
  const m = pts.length;
  let d = `M ${pts[0][0].toFixed(4)} ${pts[0][1].toFixed(4)}`;
  for (let i = 0; i < m; i++) {
    const p0 = pts[(i - 1 + m) % m];
    const p1 = pts[i];
    const p2 = pts[(i + 1) % m];
    const p3 = pts[(i + 2) % m];
    const cp1x = p1[0] + (p2[0] - p0[0]) / 6;
    const cp1y = p1[1] + (p2[1] - p0[1]) / 6;
    const cp2x = p2[0] - (p3[0] - p1[0]) / 6;
    const cp2y = p2[1] - (p3[1] - p1[1]) / 6;
    d += ` C ${cp1x.toFixed(4)} ${cp1y.toFixed(4)}, ${cp2x.toFixed(4)} ${cp2y.toFixed(4)}, ${p2[0].toFixed(4)} ${p2[1].toFixed(4)}`;
  }
  return d + ' Z';
}

const blobs = [
  generateBlobPath(
    [0.47, 0.43, 0.48, 0.42, 0.46, 0.44, 0.47, 0.43],
    [0.27, 0.30, 0.26, 0.31, 0.28, 0.29, 0.27, 0.30]
  ),
  generateBlobPath(
    [0.44, 0.48, 0.43, 0.47, 0.45, 0.46, 0.43, 0.48],
    [0.30, 0.26, 0.31, 0.27, 0.29, 0.27, 0.31, 0.26]
  ),
  generateBlobPath(
    [0.46, 0.44, 0.49, 0.42, 0.47, 0.43, 0.46, 0.45],
    [0.28, 0.31, 0.25, 0.32, 0.27, 0.30, 0.29, 0.27]
  ),
  generateBlobPath(
    [0.43, 0.47, 0.44, 0.48, 0.42, 0.47, 0.45, 0.44],
    [0.31, 0.27, 0.30, 0.26, 0.32, 0.28, 0.27, 0.31]
  ),
  generateBlobPath(
    [0.48, 0.42, 0.46, 0.44, 0.49, 0.43, 0.46, 0.44],
    [0.26, 0.32, 0.28, 0.30, 0.25, 0.31, 0.28, 0.30]
  ),
  generateBlobPath(
    [0.45, 0.46, 0.42, 0.48, 0.44, 0.46, 0.48, 0.43],
    [0.29, 0.28, 0.32, 0.26, 0.30, 0.27, 0.26, 0.32]
  ),
];
---
<BaseLayout title="記事一覧">
  <svg width="0" height="0" style="position:absolute">
    <defs>
      {blobs.map((d, i) => (
        <clipPath id={`blob${i + 1}`} clipPathUnits="objectBoundingBox">
          <path d={d} />
        </clipPath>
      ))}
    </defs>
  </svg>

  <style>
    .category-nav {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }
    .category-btn {
      padding: 0.3rem 0.9rem;
      border: 1px solid #ccc;
      border-radius: 20px;
      background: #fff;
      color: #555;
      font-size: 0.85rem;
      text-decoration: none;
      transition: all 0.2s;
    }
    .category-btn:hover, .category-btn.active {
      background: #333;
      color: #fff;
      border-color: #333;
    }
    .posts {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 2.5rem;
    }
    .card {
      background: #fff;
      border: 1.5px solid #e8e8e4;
      transition: box-shadow 0.2s;
    }
    .card:nth-child(6n+1) { clip-path: url(#blob1); }
    .card:nth-child(6n+2) { clip-path: url(#blob2); }
    .card:nth-child(6n+3) { clip-path: url(#blob3); }
    .card:nth-child(6n+4) { clip-path: url(#blob4); }
    .card:nth-child(6n+5) { clip-path: url(#blob5); }
    .card:nth-child(6n+6) { clip-path: url(#blob6); }
    .card:hover { box-shadow: 0 6px 24px rgba(0,0,0,0.12); }
    .card a { text-decoration: none; color: inherit; display: block; padding: 2rem; }
    .card-category {
      font-size: 0.75rem;
      color: #888;
      margin-bottom: 0.5rem;
      letter-spacing: 0.05em;
    }
    .card-title {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      line-height: 1.5;
    }
    .card-desc {
      font-size: 0.85rem;
      color: #666;
      line-height: 1.6;
    }
    .card-date {
      font-size: 0.75rem;
      color: #aaa;
      margin-top: 0.8rem;
    }
  </style>

  <div class="category-nav">
    <a href="/" class="category-btn active">すべて</a>
    {categories.map(cat => (
      <a href={`/category/${cat}`} class="category-btn">{cat}</a>
    ))}
  </div>

  <div class="posts">
    {posts.map(post => (
      <div class="card">
        <a href={`/blog/${post.id}`}>
          <div class="card-category">{post.data.category}</div>
          <div class="card-title">{post.data.title}</div>
          <div class="card-desc">{post.data.description}</div>
          <div class="card-date">{post.data.date}</div>
        </a>
      </div>
    ))}
  </div>
</BaseLayout>
