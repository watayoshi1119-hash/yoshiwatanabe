---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [...new Set(posts.map(p => p.data.category))];

// objectBoundingBox座標(0-1)でアメーバ形SVGパスを生成
function generateBlobPath(outerR: number[], innerR: number[]) {
  const cx = 0.5, cy = 0.5;
  const n = outerR.length;
  const pts: [number, number][] = [];
  for (let i = 0; i < n; i++) {
    const outerAngle = (i / n) * 2 * Math.PI - Math.PI / 2;
    const innerAngle = outerAngle + Math.PI / n;
    pts.push([cx + outerR[i] * Math.cos(outerAngle), cy + outerR[i] * Math.sin(outerAngle)]);
    pts.push([cx + innerR[i] * Math.cos(innerAngle), cy + innerR[i] * Math.sin(innerAngle)]);
  }
  const m = pts.length;
  let d = `M ${pts[0][0].toFixed(4)} ${pts[0][1].toFixed(4)}`;
  for (let i = 0; i < m; i++) {
    const p0 = pts[(i - 1 + m) % m];
    const p1 = pts[i];
    const p2 = pts[(i + 1) % m];
    const p3 = pts[(i + 2) % m];
    const cp1x = p1[0] + (p2[0] - p0[0]) / 3.5;
    const cp1y = p1[1] + (p2[1] - p0[1]) / 3.5;
    const cp2x = p2[0] - (p3[0] - p1[0]) / 3.5;
    const cp2y = p2[1] - (p3[1] - p1[1]) / 3.5;
    d += ` C ${cp1x.toFixed(4)} ${cp1y.toFixed(4)}, ${cp2x.toFixed(4)} ${cp2y.toFixed(4)}, ${p2[0].toFixed(4)} ${p2[1].toFixed(4)}`;
  }
  return d + ' Z';
}

const blobs = [
  generateBlobPath(
    [0.62, 0.28, 0.55, 0.22, 0.58, 0.25, 0.60, 0.20],
    [0.18, 0.38, 0.16, 0.35, 0.20, 0.32, 0.17, 0.36]
  ),
  generateBlobPath(
    [0.25, 0.60, 0.20, 0.58, 0.28, 0.55, 0.22, 0.62],
    [0.36, 0.17, 0.38, 0.18, 0.32, 0.20, 0.35, 0.16]
  ),
  generateBlobPath(
    [0.58, 0.22, 0.63, 0.25, 0.52, 0.28, 0.60, 0.20],
    [0.20, 0.35, 0.17, 0.38, 0.22, 0.33, 0.18, 0.37]
  ),
  generateBlobPath(
    [0.28, 0.55, 0.23, 0.62, 0.20, 0.58, 0.26, 0.52],
    [0.33, 0.18, 0.37, 0.16, 0.36, 0.20, 0.32, 0.22]
  ),
  generateBlobPath(
    [0.60, 0.20, 0.56, 0.28, 0.62, 0.22, 0.50, 0.25],
    [0.17, 0.38, 0.20, 0.33, 0.16, 0.36, 0.22, 0.35]
  ),
  generateBlobPath(
    [0.22, 0.62, 0.28, 0.50, 0.25, 0.60, 0.20, 0.56],
    [0.35, 0.16, 0.33, 0.22, 0.38, 0.17, 0.36, 0.20]
  ),
];
---
<BaseLayout title="記事一覧">
  <style>
    .diary-btn {
      display: block;
      text-align: center;
      margin-bottom: 2.5rem;
    }
    .diary-btn img {
      max-width: 480px;
      width: 100%;
      transition: opacity 0.2s, transform 0.2s;
    }
    .diary-btn:hover img {
      opacity: 0.85;
      transform: scale(1.02);
    }
    .category-nav {
      display: flex;
      gap: 0.5rem;
      flex-wrap: wrap;
      margin-bottom: 2rem;
    }
    .category-btn {
      padding: 0.3rem 0.9rem;
      border: 1px solid #ccc;
      border-radius: 20px;
      background: #fff;
      color: #555;
      font-size: 0.85rem;
      text-decoration: none;
      transition: all 0.2s;
    }
    .category-btn:hover, .category-btn.active {
      background: #333;
      color: #fff;
      border-color: #333;
    }
    .posts {
      display: grid;
      grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
      gap: 4rem;
    }
    .card {
      position: relative;
      min-height: 220px;
    }
    .card-blob {
      position: absolute;
      inset: 0;
      width: 100%;
      height: 100%;
    }
    .card-blob path { fill: #dff0e0; stroke: none; }
    .card:hover .card-blob path { fill: #cce8ce; }
    .card-text {
      position: relative;
      z-index: 1;
      padding: 2rem;
      text-decoration: none;
      color: inherit;
      display: flex;
      flex-direction: column;
      justify-content: center;
      align-items: center;
      text-align: center;
      min-height: 220px;
    }
    .card-title {
      font-size: 1rem;
      font-weight: 700;
      margin-bottom: 0.5rem;
      line-height: 1.5;
    }
    .card-desc {
      font-size: 0.85rem;
      color: #666;
      line-height: 1.6;
    }
    .roulette-section {
      text-align: center;
      margin: 3rem 0 3.5rem;
    }
    .roulette-label {
      font-size: 0.8rem;
      color: #aaa;
      letter-spacing: 0.1em;
      margin-bottom: 0.8rem;
    }
    .roulette-slots {
      display: flex;
      justify-content: center;
      gap: 0.3rem;
      margin-bottom: 1.2rem;
    }
    .slot {
      display: inline-block;
      font-size: 1.6rem;
      font-weight: 700;
      min-width: 3.5rem;
      padding: 0.4rem 0.6rem;
      background: #fff;
      border-radius: 8px;
      border: 1px solid #e8e8e4;
      color: #333;
      transition: color 0.1s;
    }
    .slot.spinning { color: #ccc; }
    .roulette-btn {
      padding: 0.5rem 2rem;
      border: 1px solid #ccc;
      border-radius: 20px;
      background: #fff;
      color: #555;
      font-size: 0.85rem;
      cursor: pointer;
      font-family: inherit;
      transition: all 0.2s;
    }
    .roulette-btn:hover { background: #333; color: #fff; border-color: #333; }
    .roulette-btn:disabled { opacity: 0.4; cursor: default; }
  </style>

  <script>
    const adj = ['あたらしい','ふるい','やさしい','きびしい','あかるい','くらい','おおきい','ちいさい','うれしい','かなしい','たのしい','こわい','あつい','さむい','はやい','おそい','うつくしい','みにくい','おもい','かるい','あおい','あかい','しろい','くろい','きいろい','あまい','からい','すっぱい','にがい','しょっぱい','ながい','みじかい','やわらかい','かたい','とおい','ちかい','ひろい','せまい','ふかい','あさい'];
    const par = ['の','が','を','に','と','で','から','まで','より','へ','も','は','だけ','しか','ほど','など','ごと','ずつ','きり','のみ'];
    const nou = ['とりかぶと','バーミヤン','中央線','喫煙所','紹興酒','増田書店','バス停','夕焼け','珈琲','文庫本','タバコ','公衆電話','踏切','猫','傘','レシート','自販機','橋','月','夢','鍵','手紙','電球','砂糖','鉛筆','窓','骨董品','地図','雑踏','記憶','影','時計','石畳','缶詰','川','ノート','灰皿','切符','路地','電線'];

    function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

    const btn = document.getElementById('roulette-btn');
    const slots = [
      { el: document.getElementById('slot-adj'), list: adj },
      { el: document.getElementById('slot-par'), list: par },
      { el: document.getElementById('slot-nou'), list: nou },
    ];

    btn.addEventListener('click', () => {
      btn.disabled = true;
      const results = slots.map(s => pick(s.list));
      let tick = 0;
      const total = 24;
      const interval = setInterval(() => {
        tick++;
        slots.forEach((s, i) => {
          const done = tick > total - (slots.length - i) * 5;
          s.el.classList.toggle('spinning', !done);
          s.el.textContent = done ? results[i] : pick(s.list);
        });
        if (tick >= total) {
          clearInterval(interval);
          slots.forEach((s, i) => { s.el.textContent = results[i]; });
          btn.disabled = false;
        }
      }, 80);
    });
  </script>

  <a href="/diary" class="diary-btn">
    <img src="/nikki.png" alt="日記" />
  </a>

  <div class="category-nav">
    <a href="/" class="category-btn active">すべて</a>
    {categories.map(cat => (
      <a href={`/category/${cat}`} class="category-btn">{cat}</a>
    ))}
  </div>

  <div class="roulette-section">
    <div class="roulette-label">今日のラッキーアイテム</div>
    <div class="roulette-slots">
      <span class="slot" id="slot-adj">？</span>
      <span class="slot" id="slot-par">？</span>
      <span class="slot" id="slot-nou">？</span>
    </div>
    <button class="roulette-btn" id="roulette-btn">まわす</button>
  </div>

  <div class="posts">
    {posts.map((post, i) => (
      <div class="card">
        <svg class="card-blob" viewBox="0 0 1 1" preserveAspectRatio="none" xmlns="http://www.w3.org/2000/svg">
          <path d={blobs[i % blobs.length]} />
        </svg>
        <a href={`/blog/${post.id}`} class="card-text">
          <div class="card-title">{post.data.title}</div>
          <div class="card-desc">{post.data.description}</div>
        </a>
      </div>
    ))}
  </div>
</BaseLayout>
