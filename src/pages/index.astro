---
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

const posts = (await getCollection('blog')).sort(
  (a, b) => new Date(b.data.date).getTime() - new Date(a.data.date).getTime()
);

const categories = [...new Set(posts.map(p => p.data.category))];
const bookCount = posts.filter(p => p.data.category === '本').length;
// 記事ごとにアメーバのサイズをランダムに（ビルド時に固定）
// 同明度・同彩度で色相を自由に変えたパステル
const palette = [
  'hsl(340,55%,86%)', // ピンク
  'hsl(210,55%,86%)', // スカイブルー
  'hsl(270,45%,86%)', // ラベンダー
  'hsl(25, 65%,86%)', // ピーチ
  'hsl(160,50%,83%)', // ミントグリーン
  'hsl(50, 65%,86%)', // レモン
  'hsl(190,55%,83%)', // アクアマリン
  'hsl(10, 55%,86%)', // サーモン
];
// タイトルが1行で収まる円サイズを計算
// 日本語1文字 ≈ 14px、テキストが円の内接正方形に収まるには diameter = textW * √2
const CHAR_PX = 14;
const cardData = posts.map((post, i) => {
  const textW = post.data.title.length * CHAR_PX;
  const size = Math.ceil(textW * 1.45) + 24; // √2≈1.41 + 少し余白
  return { size, color: palette[i % palette.length] };
});

function generateBlobPath(outerR: number[], innerR: number[]) {
  const cx = 0.5, cy = 0.5;
  const n = outerR.length;
  const pts: [number, number][] = [];
  for (let i = 0; i < n; i++) {
    const outerAngle = (i / n) * 2 * Math.PI - Math.PI / 2;
    const innerAngle = outerAngle + Math.PI / n;
    pts.push([cx + outerR[i] * Math.cos(outerAngle), cy + outerR[i] * Math.sin(outerAngle)]);
    pts.push([cx + innerR[i] * Math.cos(innerAngle), cy + innerR[i] * Math.sin(innerAngle)]);
  }
  const m = pts.length;
  let d = `M ${pts[0][0].toFixed(4)} ${pts[0][1].toFixed(4)}`;
  for (let i = 0; i < m; i++) {
    const p0 = pts[(i - 1 + m) % m];
    const p1 = pts[i];
    const p2 = pts[(i + 1) % m];
    const p3 = pts[(i + 2) % m];
    const cp1x = p1[0] + (p2[0] - p0[0]) / 3.5;
    const cp1y = p1[1] + (p2[1] - p0[1]) / 3.5;
    const cp2x = p2[0] - (p3[0] - p1[0]) / 3.5;
    const cp2y = p2[1] - (p3[1] - p1[1]) / 3.5;
    d += ` C ${cp1x.toFixed(4)} ${cp1y.toFixed(4)}, ${cp2x.toFixed(4)} ${cp2y.toFixed(4)}, ${p2[0].toFixed(4)} ${p2[1].toFixed(4)}`;
  }
  return d + ' Z';
}

const blobs = [
  generateBlobPath([0.62,0.28,0.55,0.22,0.58,0.25,0.60,0.20],[0.18,0.38,0.16,0.35,0.20,0.32,0.17,0.36]),
  generateBlobPath([0.25,0.60,0.20,0.58,0.28,0.55,0.22,0.62],[0.36,0.17,0.38,0.18,0.32,0.20,0.35,0.16]),
  generateBlobPath([0.58,0.22,0.63,0.25,0.52,0.28,0.60,0.20],[0.20,0.35,0.17,0.38,0.22,0.33,0.18,0.37]),
  generateBlobPath([0.28,0.55,0.23,0.62,0.20,0.58,0.26,0.52],[0.33,0.18,0.37,0.16,0.36,0.20,0.32,0.22]),
  generateBlobPath([0.60,0.20,0.56,0.28,0.62,0.22,0.50,0.25],[0.17,0.38,0.20,0.33,0.16,0.36,0.22,0.35]),
  generateBlobPath([0.22,0.62,0.28,0.50,0.25,0.60,0.20,0.56],[0.35,0.16,0.33,0.22,0.38,0.17,0.36,0.20]),
];
---
<BaseLayout title="記事一覧">
  <style>
    .diary-btn {
      display: block;
      text-align: center;
      margin-bottom: 0;
    }
    .diary-btn img {
      max-width: 480px;
      width: 100%;
      transition: opacity 0.2s, transform 0.2s;
    }
    .diary-btn:hover img { opacity: 0.85; transform: scale(1.02); }

    /* ベントグリッド */
    .bento {
      display: grid;
      grid-template-columns: 1fr 1.8fr;
      gap: 20px;
    }
    .tile { border-radius: 20px; padding: 20px 24px; }

    /* タイル配置・サイズはコンテンツに合わせる */
    .tile-greeting {
      grid-column: 1; grid-row: 1;
      background: #fef9ec;
      justify-self: start; align-self: start;
    }
    .tile-diary {
      grid-column: 2; grid-row: 1;
      background: #fff;
      justify-self: start; align-self: start;
      display: flex; align-items: center;
    }
    .tile-roulette {
      grid-column: 1 / 3; grid-row: 2;
      background: #f2f2f0;
      justify-self: center; align-self: start;
      width: fit-content;
      text-align: center;
    }
    .tile-articles {
      grid-column: 1 / 3; grid-row: 3;
      background: transparent;
      padding: 0;
      justify-self: stretch;
    }
    .tile-song {
      grid-column: 1 / 3; grid-row: 4;
      background: #f8f8f6;
      justify-self: start; align-self: start;
      display: flex; align-items: center; gap: 20px;
      width: 520px;
    }

    /* 吹き出し */
    .greeting-bubble {
      font-family: 'Hachi Maru Pop', cursive;
      font-size: 1.8rem;
      color: #333;
      position: relative;
      display: inline-block;
      background: #fff;
      border: 2px solid #333;
      border-radius: 18px;
      padding: 0.5rem 1.4rem;
      line-height: 1.4;
    }
    .greeting-bubble::after {
      content: '';
      position: absolute;
      bottom: -16px; left: 24px;
      border: 9px solid transparent;
      border-top-color: #333;
    }
    .greeting-bubble::before {
      content: '';
      position: absolute;
      bottom: -11px; left: 26px;
      border: 7px solid transparent;
      border-top-color: #fef9ec;
      z-index: 1;
    }

    /* 動静ボタン */
    .tile-diary img { width: 100%; max-width: 420px; transition: transform 0.2s; }
    .tile-diary a:hover img { transform: scale(1.03); }

    /* ルーレット 1.5倍 */
    .roulette-logo { display: block; max-width: 270px; width: 100%; margin: 0 auto 16px; }
    .roulette-machine { display: inline-flex; gap: 10px; margin-bottom: 16px; }
    .roulette-window {
      width: 165px; height: 78px;
      background: #fff; border-radius: 14px;
      box-shadow: 0 1px 6px rgba(0,0,0,0.07);
      display: flex; align-items: center; justify-content: center;
    }
    .drum-item { font-size: 1.6rem; font-weight: 700; color: #333; white-space: nowrap; }
    .roulette-btn {
      display: block; margin: 0 auto;
      padding: 0.6rem 2.2rem;
      border: none; border-radius: 999px;
      background: #333; color: #fff;
      font-size: 1rem; font-family: inherit;
      cursor: pointer; transition: opacity 0.2s;
    }
    .roulette-btn:hover { opacity: 0.75; }
    .roulette-btn:disabled { opacity: 0.3; cursor: default; }

    /* 記事一覧 */
    .category-nav { display: flex; gap: 0.5rem; flex-wrap: wrap; margin: 0 auto 1.4rem; justify-content: center; }
    .category-btn {
      padding: 0.3rem 0.9rem;
      border: 1px solid #ccc; border-radius: 20px;
      background: #fff; color: #555;
      font-size: 0.82rem; text-decoration: none; transition: all 0.2s;
    }
    .category-btn:hover, .category-btn.active { background: #333; color: #fff; border-color: #333; }
    .book-counter { font-size: 0.78rem; color: #aaa; margin-left: 4px; }
    .book-counter strong { color: #555; }
    .posts {
      display: flex;
      flex-wrap: wrap;
      justify-content: center;
      align-items: center;
      gap: 2rem;
    }
    .card {
      position: relative;
      border-radius: 50%;
      flex-shrink: 0;
      transition: filter 0.2s;
    }
    .card:hover { filter: brightness(0.95); }
    .card-text {
      position: absolute; inset: 0;
      text-decoration: none; color: inherit;
      display: flex; flex-direction: column;
      justify-content: center; align-items: center;
      text-align: center;
      padding: 1rem;
      border-radius: 50%;
    }
    .card-title { font-size: 0.88rem; font-weight: 700; white-space: nowrap; }

    /* 今日の一曲（横長） */
    .song-label { font-size: 0.7rem; color: #bbb; letter-spacing: 0.12em; white-space: nowrap; writing-mode: vertical-rl; }
    .tile-song iframe { flex: 1; height: 80px; border: none; border-radius: 12px; }
  </style>

  <script>
    // 訪問者へのひとこと（固定）
    const g = document.getElementById('greeting');
    if (g) g.textContent = 'またきたね';

    // 今日の一曲
    const tracks = [
      '2PuZC7hxsslTsJHx7Q0IN8', // DOUKUTSU - Moment Joon
      '0C9T668QTVtOnQVH7LpRrC', // lie - SEBii, lieu
      '2FppvAGabIb1dyBXBjy8lV', // Karagenki - Siero
      '0yJOqnpAsvGl6VDNa4LqMy', // Run Now - Kamui, swetty
      '3iZwn7D6ugrZdysRd8bs06', // ISOGE - Lunv Loyal
      '3um48ZL0kAqMDhnOwSSCeP', // You Came Back - KANDYTOWN
      '6AhYshWZvuR3uHeY6SLBUH', // 阿波の踊り子 - blend house
      '16iDq9o0YzEq6Ibasi92sD', // MoShPiT! - ramtoro
      '5N4reZXVKruh2upgEWaUP0', // cesium - AssToro
      '1sd6j2a7zm0nVRJQ77k5HS', // Real Love - Watson, Sonsi
      '7m3uPc3OBWLYaay0biiTn0', // よるのとしょかん - 鈴木真海子
    ];
    const trackId = tracks[Math.floor(Math.random() * tracks.length)];
    const iframe = document.getElementById('spotify-embed');
    if (iframe) iframe.src = `https://open.spotify.com/embed/track/${trackId}?utm_source=generator`;

    const adj = ['あたらしい','ふるい','やさしい','きびしい','あかるい','くらい','おおきい','ちいさい','うれしい','かなしい','たのしい','こわい','あつい','さむい','はやい','おそい','うつくしい','みにくい','おもい','かるい','あおい','あかい','しろい','くろい','あまい','からい','すっぱい','にがい','ながい','みじかい','やわらかい','かたい','とおい','ちかい','ひろい','せまい','ふかい','あさい'];
    const nou = ['とりかぶと','バーミヤン','中央線','喫煙所','紹興酒','増田書店','バス停','夕焼け','珈琲','文庫本','タバコ','公衆電話','踏切','猫','傘','レシート','自販機','橋','月','夢','鍵','手紙','電球','砂糖','鉛筆','窓','骨董品','地図','雑踏','記憶','影','時計','石畳','缶詰','川','ノート','灰皿','切符','路地','電線'];

    function pick(arr) { return arr[Math.floor(Math.random() * arr.length)]; }

    function spinSlot(el, list, result, ticks, delay, onDone) {
      let t = 0;
      const iv = setInterval(() => {
        t++;
        const done = t >= ticks;
        el.textContent = done ? result : pick(list);
        if (done) { clearInterval(iv); setTimeout(onDone, delay); }
      }, 60);
    }

    const btn = document.getElementById('roulette-btn');
    const drumAdj = document.getElementById('drum-adj');
    const drumNou = document.getElementById('drum-nou');

    btn.addEventListener('click', () => {
      btn.disabled = true;
      const rAdj = pick(adj);
      const rNou = pick(nou);
      spinSlot(drumAdj, adj, rAdj, 20, 200, () => {
        spinSlot(drumNou, nou, rNou, 26, 0, () => {
          btn.disabled = false;
        });
      });
    });
  </script>

  <div class="bento">

    <!-- 左：吹き出し -->
    <div class="tile tile-greeting">
      <span class="greeting-bubble" id="greeting"></span>
    </div>

    <!-- 右：動静ボタン -->
    <div class="tile tile-diary">
      <a href="/diary">
        <img src="/nikki.png" alt="日記" />
      </a>
    </div>

    <!-- 全幅：ラッキーアイテム（中央） -->
    <div class="tile tile-roulette">
      <img src="/ラッキーアイテム.png" alt="今日のラッキーアイテム" class="roulette-logo" />
      <div class="roulette-machine">
        <div class="roulette-window"><div class="drum-item" id="drum-adj">？</div></div>
        <div class="roulette-window"><div class="drum-item" id="drum-nou">？</div></div>
      </div>
      <button class="roulette-btn" id="roulette-btn">まわす</button>
    </div>

    <!-- 全幅：記事一覧（中央揃え） -->
    <div class="tile tile-articles">
      <div class="category-nav">
        <a href="/" class="category-btn active">すべて</a>
        {categories.map(cat => (
          <a href={`/category/${cat}`} class="category-btn">{cat}</a>
        ))}
        <span class="book-counter">今年読んだ本 <strong>{bookCount}</strong> 冊</span>
      </div>
      <div class="posts">
        {posts.map((post, i) => (
          <div class="card" style={`width:${cardData[i].size}px; height:${cardData[i].size}px; background:${cardData[i].color};`}>
            <a href={`/blog/${post.id}`} class="card-text">
              <div class="card-title">{post.data.title}</div>
            </a>
          </div>
        ))}
      </div>
    </div>

    <!-- 全幅：今日の一曲（横長、最下部） -->
    <div class="tile tile-song">
      <span class="song-label">今日の一曲</span>
      <iframe id="spotify-embed" src="" height="80" allow="autoplay; clipboard-write; encrypted-media; fullscreen; picture-in-picture" loading="lazy"></iframe>
    </div>

  </div>
</BaseLayout>
