---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'ライフスタイルブログ' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | yoshiwatanabe</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: '游ゴシック', 'Yu Gothic', YuGothic, sans-serif;
      color: #333;
      background: #fafaf8;
      line-height: 1.8;
    }
    header {
      padding: 2rem 1.5rem 0;
      text-align: center;
    }
    header a.logo {
      font-size: 1.3rem;
      font-weight: 700;
      color: #333;
      text-decoration: none;
      letter-spacing: 0.05em;
    }
    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }
    footer {
      text-align: center;
      padding: 2rem;
      color: #aaa;
      font-size: 0.8rem;
      border-top: 1px solid #e8e8e4;
      margin-top: 4rem;
    }
    .bg-blobs {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    body > *:not(.bg-blobs) { position: relative; z-index: 1; }
  </style>
</head>
<body>
  <svg class="bg-blobs" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice">
    <!-- 左上：薄いオレンジ・見切れ・小さめ -->
    <path d="M -4 5 C 2 -1 12 1 14 7 C 17 14 12 21 5 22 C -1 23 -6 18 -7 12 C -8 7 -8 9 -4 5 Z"
      fill="#f9c88a" opacity="0.65" />
    <!-- 右上：中間オレンジ・見切れ -->
    <path d="M 88 -3 C 93 -8 102 -3 104 4 C 107 12 102 20 95 19 C 88 18 83 12 85 5 C 86 1 85 1 88 -3 Z"
      fill="#f7a85a" opacity="0.6" />
    <!-- 右中：濃いオレンジ・見切れ -->
    <path d="M 96 52 C 100 46 108 47 110 54 C 113 62 107 70 100 69 C 93 68 89 61 91 54 C 92 50 94 56 96 52 Z"
      fill="#f47840" opacity="0.55" />
    <!-- 右下：黄色・見切れ -->
    <path d="M 82 88 C 87 82 96 83 98 90 C 100 97 95 105 87 104 C 80 103 76 97 78 90 C 79 86 80 92 82 88 Z"
      fill="#f5e040" opacity="0.5" />
    <!-- 中央上寄り：黄色・小 -->
    <path d="M 44 18 C 47 14 53 14 55 18 C 58 23 55 29 50 30 C 45 31 41 27 42 22 C 42 19 43 21 44 18 Z"
      fill="#f8e84e" opacity="0.4" />
    <!-- 中央左：薄オレンジ・小 -->
    <path d="M 20 55 C 23 50 30 50 32 56 C 34 62 29 68 23 67 C 17 66 14 60 17 55 C 18 52 18 58 20 55 Z"
      fill="#f9c070" opacity="0.35" />
    <!-- 左下：黄色・見切れ -->
    <path d="M -6 82 C -2 76 6 77 8 83 C 10 90 5 98 -2 97 C -8 96 -12 90 -10 84 C -9 80 -9 86 -6 82 Z"
      fill="#f5e040" opacity="0.5" />
  </svg>
  <header>
    <a href="/" class="logo">yoshiwatanabe</a>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>© 2026 yoshiwatanabe</p>
  </footer>
</body>
</html>
