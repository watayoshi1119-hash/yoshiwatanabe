---
interface Props {
  title: string;
  description?: string;
}
const { title, description = 'ライフスタイルブログ' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <title>{title} | yoshiwatanabe</title>
  <style>
    * { box-sizing: border-box; margin: 0; padding: 0; }
    body {
      font-family: '游ゴシック', 'Yu Gothic', YuGothic, sans-serif;
      color: #333;
      background: #fafaf8;
      line-height: 1.8;
    }
    header {
      background: #fff;
      border-bottom: 1px solid #e8e8e4;
      padding: 0 1.5rem;
    }
    .header-inner {
      max-width: 900px;
      margin: 0 auto;
      display: flex;
      align-items: center;
      justify-content: space-between;
      height: 60px;
    }
    header a.logo {
      font-size: 1.3rem;
      font-weight: 700;
      color: #333;
      text-decoration: none;
      letter-spacing: 0.05em;
    }
    nav a {
      margin-left: 1.5rem;
      color: #666;
      text-decoration: none;
      font-size: 0.9rem;
    }
    nav a:hover { color: #333; }
    main {
      max-width: 900px;
      margin: 0 auto;
      padding: 2rem 1.5rem;
    }
    footer {
      text-align: center;
      padding: 2rem;
      color: #aaa;
      font-size: 0.8rem;
      border-top: 1px solid #e8e8e4;
      margin-top: 4rem;
    }
    .bg-blobs {
      position: fixed;
      inset: 0;
      width: 100%;
      height: 100%;
      pointer-events: none;
      z-index: 0;
      overflow: hidden;
    }
    body > *:not(.bg-blobs) { position: relative; z-index: 1; }
  </style>
</head>
<body>
  <svg class="bg-blobs" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 100 100" preserveAspectRatio="xMidYMid slice">
    <!-- 左上：薄いオレンジ・見切れ -->
    <path d="M -5 8 C 5 -2 20 2 25 12 C 32 24 24 38 12 40 C 0 42 -8 34 -12 24 C -16 14 -14 16 -5 8 Z"
      fill="#f9d4a0" opacity="0.6" />
    <!-- 右上：中間オレンジ・見切れ -->
    <path d="M 80 -8 C 90 -15 108 -5 112 8 C 118 22 108 36 96 34 C 84 32 76 20 78 8 C 79 2 76 -4 80 -8 Z"
      fill="#f7b86a" opacity="0.55" />
    <!-- 右下：濃いオレンジ・見切れ -->
    <path d="M 88 78 C 98 68 116 72 118 86 C 120 98 108 110 94 108 C 80 106 72 96 76 84 C 78 76 82 84 88 78 Z"
      fill="#f4894a" opacity="0.5" />
    <!-- 中央やや左：黄色 -->
    <path d="M 28 42 C 34 34 46 34 50 42 C 56 52 50 64 40 66 C 30 68 22 60 22 50 C 22 44 24 48 28 42 Z"
      fill="#f9e84a" opacity="0.35" />
    <!-- 中央やや右：薄いオレンジ -->
    <path d="M 58 50 C 64 40 78 40 82 52 C 86 62 78 74 66 72 C 56 70 50 62 52 52 C 53 46 54 56 58 50 Z"
      fill="#f9c46a" opacity="0.3" />
    <!-- 左下：黄色・見切れ -->
    <path d="M -10 75 C -2 65 12 66 16 76 C 20 86 12 98 0 98 C -10 98 -18 90 -16 80 C -15 74 -16 82 -10 75 Z"
      fill="#f5e040" opacity="0.45" />
  </svg>
  <header>
    <div class="header-inner">
      <a href="/" class="logo">yoshiwatanabe</a>
      <nav>
        <a href="/">記事一覧</a>
        <a href="/about">about</a>
      </nav>
    </div>
  </header>
  <main>
    <slot />
  </main>
  <footer>
    <p>© 2026 yoshiwatanabe</p>
  </footer>
</body>
</html>
